# Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_KEY=your-service-role-secret-key-here

# Anthropic (Claude AI Assistant)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (fallback AI Assistant)
OPENAI_API_KEY=your-openai-api-key-here

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Resend (Email)
RESEND_API_KEY=your-resend-api-key-here

# Business Rules
LEAD_TIME_DAYS=45
MAX_UPLOAD_BYTES=26214400
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3001","https://ecommerce-bi-platform.vercel.app"]
CORS_ORIGIN_REGEX=

# Environment
ENVIRONMENT=development
